{
  "name": "charlie-ui-mcp",
  "version": "0.1.0",
  "description": "MCP server for the Charlie UI component library — gives AI agents full access to component docs, props, usage examples, design tokens, and theming guides.",
  "type": "module",
  "bin": {
    "charlie-ui-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:registry": "tsx scripts/build-registry.ts",
    "build": "npm run build:registry && tsup",
    "dev": "npm run build:registry && tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "charlie-ui",
    "component-library",
    "ai",
    "react"
  ]
}
